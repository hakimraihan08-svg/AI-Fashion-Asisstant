# 2. DATA SCHEMA REGISTRATION (STRUCTURED DATA LAYER)
# =====================================================================
class UserFeatures(BaseModel):
    gender: str = Field(description="Intended presentation style or gender expression of the outfit")
    skin_tone: str = Field(description="General color palette context or neutral")
    hairstyle: str = Field(description="Hair style presentation")
    body_type_characteristics: str = Field(description="Overall outfit silhouette and fit characteristics")

class CurrentOutfit(BaseModel):
    style: str
    color: str
    material: str

class OutfitAnalysis(BaseModel):
    advantages: List[str] = Field(description="Must contain exactly 2 advantages")
    areas_for_improvement: List[str] = Field(description="Must contain exactly 2 areas for improvement")

class Module1Output(BaseModel):
    user_features: UserFeatures
    current_outfit: CurrentOutfit
    analysis: OutfitAnalysis
    base_image_b64: str = Field(description="Original user profile image encoded in base64 string")

class WardrobeItemTags(BaseModel):
    category: str = Field(description="Main clothing category, e.g., shirt, pants, jacket")
    sub_category: str = Field(description="Specific type, e.g., cargo pants, slim-fit chinos")
    dominant_color: str = Field(description="Primary background color, e.g., dark indigo, warm khaki")
    secondary_color: str = Field(description="Accent or pattern color if any, otherwise 'none'")
    color_tone: str = Field(description="Tone classification, e.g., pastel, earth-tone")
    material_texture: str = Field(description="Estimated fabric material and weave, e.g., cotton twill")
    fit_type: str = Field(description="Silhouette fit, e.g., relaxed fit, oversized")
    neckline_or_collar: str = Field(description="Neck or collar style, e.g., crew neck, open collar")
    sleeve_or_length: str = Field(description="Length type, e.g., short-sleeve, long-sleeve")
    pattern_or_print: str = Field(description="Surface design, e.g., solid color, stripes")
    clothing_image_b64: str = Field(description="Original item image encoded in base64 string")

class SelectedWardrobeDetails(BaseModel):
    id_baju: str = Field(description="The matching id_baju chosen from the inventory, e.g., 'baju_images_1'")
    item_description: str = Field(description="Clean, granular fashion description of the item based on Module 2 tags.")

class Module3StandardOutput(BaseModel):
    category: str = Field(description="The matching fashion category style name, e.g., 'Smart Business Formal'")
    selected_items: List[SelectedWardrobeDetails] = Field(description="List of specific wardrobe items chosen by the AI with their IDs and granular descriptions.")    
    styling_advice: str = Field(description="A paragraph under 100 words explaining why this specific combination flatters their body shape shortcomings.")
    image_generation_prompt: str = Field(description="High-definition prompt for image generation in English.")

class WebCatalogDetails(BaseModel):
    selected_clothes: List[str] = Field(description="List of selected clothes from web stores like Uniqlo or H&M.")
    explanation: str = Field(description="A paragraph under 100 words explaining why this new outfit can flatter their shortcomings.")

class Module3WebCatalogOutput(BaseModel):
    category: str = Field(description="The matching fashion category style name, e.g., 'Casual'")
    styling_advice: WebCatalogDetails = Field(description="Structured object containing selected clothes array and text explanation.")
    image_generation_prompt: str = Field(description="High-definition prompt for image generation in English.")

