# 3. UTILITY & CONVERSION HELPER LAYER
# =====================================================================
def get_images_by_pattern(prefix_pattern: str) -> List[str]:
    valid_extensions = ['jpg', 'jpeg', 'png', 'webp', 'JPG', 'PNG', 'JPEG']
    matched_files = []
    for ext in valid_extensions:
        search_pattern = os.path.join(BASE_DIR, f"{prefix_pattern}*.{ext}")
        matched_files.extend(glob.glob(search_pattern))
    return sorted(list(set(matched_files)))

def encode_image_to_base64(image_path: str) -> str:
    with open(image_path, "rb") as img_file:
        return base64.b64encode(img_file.read()).decode('utf-8')

