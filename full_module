def run_module_1_vision_analysis(image_path: str) -> Module1Output:
    print("\n--- Running Module 1: OpenAI Vision Analysis Agent ---")
    base64_image = encode_image_to_base64(image_path)
    
    vision_prompt = """
    You are an expert fashion consultant and computer vision analyzer. 
    Analyze the person in the uploaded photo with high precision. 
    Identify their structural body shape, skin tone palette, hairstyle presentation, and the precise design details of their current outfit.

    🚫 NEGATIVE PROMPT & SYSTEM GUARDRAILS:
    1. DO NOT include background objects, room furniture, shadows, or photo quality in the analysis.
    2. NO BIAS OR HALLUCINATION: Maintain strict consistency with the visible gender presentation and body proportions.
    """
    
    max_retries = 3
    for attempt in range(1, max_retries + 1):
        try:
            completion = openai_client.beta.chat.completions.parse(
                model="gpt-5.5",
                messages=[
                    {
                        "role": "user",
                        "content": [
                            {"type": "text", "text": vision_prompt},
                            {"type": "image_url", "image_url": {"url": f"data:image/jpeg;base64,{base64_image}"}}
                        ]
                    }
                ],
                response_format=Module1Output
            )
            parsed_output = completion.choices[0].message.parsed
            parsed_output.base_image_b64 = base64_image
            return parsed_output
        except Exception as e:
            if attempt < max_retries: time.sleep(2)
            else: raise e

def run_module_2_wardrobe_tagging(image_path: str) -> WardrobeItemTags:
    print(f"-> Running Module 2: Tagging Agent scanning clothing item...")
    base64_image = encode_image_to_base64(image_path)

    tagging_prompt = """
    You are an advanced multi-modal fashion analysis engine. 
    Analyze the uploaded single clothing item image in extreme, granular detail.
    """
    
    max_retries = 3
    for attempt in range(1, max_retries + 1):
        try:
            completion = openai_client.beta.chat.completions.parse(
                model="gpt-5.5",
                messages=[
                    {
                        "role": "user",
                        "content": [
                            {"type": "text", "text": tagging_prompt},
                            {"type": "image_url", "image_url": {"url": f"data:image/jpeg;base64,{base64_image}"}}
                        ]
                    }
                ],
                response_format=WardrobeItemTags,
                temperature=1
            )
            parsed_tags = completion.choices[0].message.parsed
            parsed_tags.clothing_image_b64 = base64_image
            return parsed_tags
        except Exception as e:
            if attempt < max_retries: time.sleep(2)
            else: raise e

def run_module_3_stylist_agent_v3(path_m1_json: str, list_wardrobe_data: List[dict], condition_type: str = "3", chosen_style: str = "any"):
    print(f"\n--- Running Module 3: OpenAI Stylist Agent [CONDITION MODE {condition_type}] ---")
    
    with open(path_m1_json, "r", encoding="utf-8") as f:
        data_m1 = json.load(f)

    user_features_context = json.dumps(data_m1.get('user_features', {}))
    analysis_context = json.dumps(data_m1.get('analysis', {}))

    # 🛡️ FILTER STRIPPER: Strip huge base64 strings before API inference to reduce token costs up to 90%
    cleaned_wardrobe_payload = []
    for item in list_wardrobe_data:
        item_copy = item.copy()
        item_copy.pop("clothing_image_b64", None)  # Drops base64 text payload from context window
        cleaned_wardrobe_payload.append(item_copy)

    if condition_type == "1":
        response_schema_target = Module3StandardOutput
        constraint_instruction = f"""
        Constraints: You MUST ONLY use and assemble the clothing items provided in the 'Selected Wardrobe Inventory Items' list below. 
        Each item has a unique 'id_baju' field. DO NOT invent or add any entirely new garments.
        
        CRITICAL STYLE REQUIREMENT: Orchestrate these items to match the targeted theme: '{chosen_style.upper()}'.
        """
        task_instruction = f"""
        Task 1: For every clothing item selected, create an object inside 'selected_items' with its exact 'id_baju' and clean fashion description.
        Task 2: Inside 'styling_advice', write an analysis under 100 words explicitly mentioning the chosen 'id_baju' codes.
        Task 3: Write a high-definition image generation prompt stored in 'image_generation_prompt' matching the '{chosen_style.upper()}' vibe.
        """

    elif condition_type == "2":
        response_schema_target = Module3WebCatalogOutput
        constraint_instruction = f"""
        Constraints: You MUST ONLY select and recommend clothing items from the 'Available Web Catalog Store' list provided below.
        These are real items fetched via a high-accuracy automated web crawler from Uniqlo and H&M.
        DO NOT invent, hallucinate, or introduce any brand new items or clothing models that do not exist in this provided catalog list.
        
        CRITICAL STYLE REQUIREMENT: Align the overall selection with the targeted theme: '{chosen_style.upper()}'.
        """
        task_instruction = f"""
        Task 1: Inside 'styling_advice.selected_clothes', create a structured list of strings containing the exact 'brand', 'item_name', and 'dominant_color' of the products you chose from the catalog (e.g., 'Uniqlo: Smart Ankle Pants (Charcoal Black)').
        Task 2: Inside 'styling_advice.explanation', write a paragraph under 100 words explaining to the user why this specific outfit combination from the store flatters their body shape shortcomings.
        Task 3: Write a high-definition image generation prompt stored in 'image_generation_prompt'. Combine the user's features with the exact visual attributes of the chosen catalog products.
        """

    else:
        response_schema_target = Module3StandardOutput
        constraint_instruction = f"""
        Design a fully generative outfit for the user based on physical features matching the '{chosen_style.upper()}' theme.
        """
        task_instruction = f"""
        Task 1: Keep 'selected_items' empty [].
        Task 2: Inside 'styling_advice', write an analysis under 100 words.
        Task 3: Write a high-definition image generation prompt stored in 'image_generation_prompt'.
        """

    context_prompt = f"""
    You are a top-tier personal fashion stylist director. 
    
    [User Profile Context]
    User Features: {user_features_context}
    Outfit Analysis & Shortcomings: {analysis_context}
    
    [Core Directives & Constraints]
    {constraint_instruction}
    
    [Selected Wardrobe Inventory Items (Only applicable for Condition 1)]
    { json.dumps(cleaned_wardrobe_payload, indent=2) }
    
    [Required Action Tasks]
    {task_instruction}

    CRITICAL CONSTRAINTS FOR IMAGE PROMPT:
    - CAMERA COMPOSITION: A full-body shot captured from a medium-long distance. Head to toe fully visible.
    - BACKGROUND CONSTRAINT: Focus strictly on a SOLID PURE WHITE back-drop, with absolutely NO studio props.
    """
    
    max_retries = 3
    for attempt in range(1, max_retries + 1):
        try:
            completion = openai_client.beta.chat.completions.parse(
                model="gpt-5.5",
                messages=[{"role": "user", "content": context_prompt}],
                response_format=response_schema_target,
                temperature=1
            )
            return completion.choices[0].message.parsed
        except Exception as e:
            if attempt < max_retries: time.sleep(2)
            else: raise e
    
def run_module_4_image_generator(input_json_path: str, output_folder: str):
    print("\n--- Running Module 4: OpenAI Image Generator Agent (gpt-image-2) ---")
    
    with open(input_json_path, "r", encoding="utf-8") as f:
        data_m3 = json.load(f)
        
    raw_prompt = data_m3.get("image_generation_prompt")
    if not raw_prompt:
        raise ValueError("Missing key 'image_generation_prompt' in source JSON file.") 
    print(f"[DEBUG] Executing Creative Prompt: {raw_prompt}")
    save_image_path = os.path.join(output_folder, "recommended_outfit_lookbook.png")
    
    try:
        response = openai_client.images.generate(
            model="gpt-image-2",
            prompt=raw_prompt,
            size="1024x1024",
            quality="low"
        )
        dalle_url = getattr(response.data[0], 'url', None)
        dalle_b64 = getattr(response.data[0], 'b64_json', None)
        
        if dalle_url and dalle_url != "None":
            print(f"[DEBUG] Remote URL Active. Downloading generated image asset...")
            img_data = requests.get(dalle_url).content 
            with open(save_image_path, "wb") as f: f.write(img_data) 
            print(f"✅ Success! Recommendation lookbook image saved via URL to: {save_image_path}") 
        elif dalle_b64:
            print(f"[DEBUG] Base64 String Active. Decoding image binary locally...")
            img_bytes = base64.b64decode(dalle_b64)
            with open(save_image_path, "wb") as f: f.write(img_bytes)
            print(f"✅ Success! Recommendation lookbook image saved via Base64 to: {save_image_path}")
        else:
            print("❌ Failure: Server response payload contains no image data paths.")
    except Exception as err:
        print(f"❌ Image generation request failed. Details: {err}")

