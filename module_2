import os
import glob
import json
import time
import base64
import traceback
from pydantic import BaseModel, Field
from openai import OpenAI

# =====================================================================
# 1. DIRECTORY CONFIGURATION & INITIALIZATION
# =====================================================================
BASE_DIR = os.path.dirname(os.path.abspath(__file__))

# Setup input and output directory paths
DIR_INPUT_WARDROBE = os.path.join(BASE_DIR, "wardrobe_test")
DIR_OUTPUT_METADATA = os.path.join(BASE_DIR, "module2_output") 

# Ensure internal system folders exist locally
for folder_path in [DIR_INPUT_WARDROBE, DIR_OUTPUT_METADATA]:
    os.makedirs(folder_path, exist_ok=True)

# System Authentication Configuration
OPENAI_API_KEY = ""
openai_client = OpenAI(api_key=OPENAI_API_KEY)

# =====================================================================
# 2. PYDANTIC OBJECT REGISTRATION (STRUCTURED DATA MODEL)
# =====================================================================
class WardrobeItemTags(BaseModel):
    id_baju: str = Field(description="Unique identifier dynamically injected based on filename, e.g., 'baju_1'")
    category: str = Field(description="Main clothing category, e.g., shirt, pants, jacket, dress, skirt, knitwear")
    sub_category: str = Field(description="Specific type, e.g., oversized overshirt, cargo pants, ribbed cardigan, slim-fit chinos")
    dominant_color: str = Field(description="Primary background color, e.g., dark indigo, olive green, cream, heather gray")
    secondary_color: str = Field(description="Accent or pattern color if any, otherwise 'none'")
    color_tone: str = Field(description="Tone classification, e.g., pastel, earth-tone, monochrome, vibrant, muted")
    material_texture: str = Field(description="Estimated fabric material and weave, e.g., sturdy denim, smooth cotton jersey, ribbed knit, cotton twill")
    fit_type: str = Field(description="Silhouette fit, e.g., relaxed fit, oversized, tailored, regular fit, cropped")
    neckline_or_collar: str = Field(description="Neck or collar style, e.g., crew neck, V-neck, open collar, button-down collar, halter-neck, none")
    sleeve_or_length: str = Field(description="Length type, e.g., short-sleeve, long-sleeve, ankle-length, cropped-length, sleeveless")
    pattern_or_print: str = Field(description="Surface design, e.g., solid color, stripes, plaid, graphic print, minimalist text, heathered texture")
    clothing_image_b64: str = Field(description="The original clothing input image encoded in base64 string, preserved as a visual state resource.")

# =====================================================================
# 3. UTILITY & IMAGE PROCESSING HELPERS
# =====================================================================
def fetch_local_wardrobe_images(folder_path: str) -> list:
    """Scans the targeted folder for images matching popular web extensions."""
    valid_extensions = ['jpg', 'jpeg', 'png', 'webp', 'JPG', 'PNG', 'JPEG', 'WEBP']
    matched_image_paths = []
    for ext in valid_extensions:
        matched_image_paths.extend(glob.glob(os.path.join(folder_path, f"*.{ext}")))
    return sorted(list(set(matched_image_paths)))

def convert_image_to_base64(image_path: str) -> str:
    """Reads a local binary image asset and encodes it to a secure Base64 UTF-8 string."""
    with open(image_path, "rb") as img_file:
        return base64.b64encode(img_file.read()).decode('utf-8')

# =====================================================================
# 4. SINGLE ASSET COMPUTER VISION PROCESSING ENGINE
# =====================================================================
def run_single_wardrobe_tagging_agent(image_path: str, asset_clean_id: str) -> WardrobeItemTags:
    """
    Submits a single base64 string clothing asset to OpenAI multi-modal vision engine 
    and returns parsed, validated structured fashion tags mapping back to Pydantic rules.
    """
    base64_image = convert_image_to_base64(image_path)

    detailed_tagging_prompt = """
    You are an advanced multi-modal fashion analysis engine and expert textile grader. 
    Your task is to analyze the uploaded single clothing item image in extreme, granular detail and extract its physical, structural, and aesthetic attributes.
    
    Strictly follow these execution directives:
    1. Identify the precise sub-category classification, tailoring silhouette, and garment fit architecture.
    2. Break down the exact color palette (including shade nuances like dark indigo, charcoal, sage green, warm khaki) and specific color tones.
    3. Determine technical design elements such as weave pattern, sleeve structure, hardware (zippers, buttons), cuffs, and neckline cuts.

    🚫 NEGATIVE PROMPT & SYSTEM GUARDRAILS (STRICTLY ADHERE TO THESE):
    1. FOCUS ON GARMENT ONLY: Ignore hangers, background walls, studio lighting gear, floors, or mannequin body parts. Analyze ONLY the fabric item itself.
    2. NO VISUAL HALLUCINATION: Output attributes strictly based on what is visually verifiable in the photo. Do not assume or invent unseen features (e.g., do not guess back-pocket styles if only the front is visible).
    3. OBJECTIVE TEXTILE TERMINOLOGY: Avoid subjective or generic words like "beautiful", "good quality", or "nice look". Use concrete fashion industry terms (e.g., "pleated wide-leg fit", "heavyweight cotton twill", "ribbed knit cuffs").
    4. ZERO BIAS: If colors or features are ambiguous due to studio lighting/shadows, classify them under standard neutral categories (e.g., "muted earth-tone", "solid pattern") rather than making extreme assumptions.
    """
    
    max_retries = 3
    for attempt in range(1, max_retries + 1):
        try:
            completion = openai_client.beta.chat.completions.parse(
                model="gpt-5.5",
                messages=[
                    {
                        "role": "user",
                        "content": [
                            {"type": "text", "text": detailed_tagging_prompt},
                            {"type": "image_url", "image_url": {"url": f"data:image/jpeg;base64,{base64_image}"}}
                        ]
                    }
                ],
                response_format=WardrobeItemTags,
                temperature=1
            )
            
            parsed_metadata = completion.choices[0].message.parsed
            
            # Injecting state control identities back into the Pydantic data container
            parsed_metadata.id_baju = asset_clean_id
            parsed_metadata.clothing_image_b64 = base64_image
            
            return parsed_metadata
            
        except Exception as api_error:
            print(f"   ⚠️ Connection attempt {attempt}/{max_retries} failed: {api_error}")
            if attempt < max_retries:
                time.sleep(2)
            else:
                raise api_error

# =====================================================================
# 5. BATCH COMPILATION & HOOK ORCHESTRATION LAYER
# =====================================================================
def run_module_2_batch_processing():
    """
    Orchestration layer that scans the localized input folder, runs vision tags loops,
    and bundles the resulting items into a single compiled catalog payload document.
    """
    print("==========================================================")
    print("🚀 INITIALIZING MODULE 2: COMBINING ALL WARDROBE ITEMS INTO ONE JSON")
    print("==========================================================")
    
    target_clothing_assets = fetch_local_wardrobe_images(DIR_INPUT_WARDROBE)
    
    if not target_clothing_assets:
        print(f"💡 [INFO] Target folder '{DIR_INPUT_WARDROBE}' is currently empty. Drop file images to proceed.")
        return

    compiled_wardrobe_catalog = []
    total_assets = len(target_clothing_assets)
    
    for current_index, individual_image_path in enumerate(target_clothing_assets, start=1):
        raw_file_name = os.path.basename(individual_image_path)
        
        # Creates a clean ID string by omitting the file extensions (e.g., shirt_01.jpg -> baju_shirt_01)
        clean_asset_id = f"baju_{os.path.splitext(raw_file_name)[0]}"
        
        print(f"[{current_index}/{total_assets}] Processing Vision Tagging for: {raw_file_name}...")
        
        try:
            # Trigger computer vision modeling on the independent asset
            analyzed_clothing_item = run_single_wardrobe_tagging_agent(individual_image_path, clean_asset_id)
            
            # Unpack the Pydantic class object into standard dict notation and append to master container
            compiled_wardrobe_catalog.append(analyzed_clothing_item.model_dump())
            print(f"   ✅ Extraction Successful: Verified tracking anchor saved as '{clean_asset_id}'")
            
        except Exception as process_exception:
            print(f"   ❌ Critical failure processing file {raw_file_name}: {process_exception}")
            traceback.print_exc()

    # Commit compiled collection array memory block directly into a localized JSON manifest file
    if compiled_wardrobe_catalog:
        output_manifest_path = os.path.join(DIR_OUTPUT_METADATA, "wardrobe_collection.json")
        
        with open(output_manifest_path, "w", encoding="utf-8") as json_manifest_file:
            json.dump(compiled_wardrobe_catalog, json_manifest_file, indent=4)
            
        print("\n==========================================================")
        print(f"🎉 ARCHITECTURE BUNDLE COMPLETE! Generated {len(compiled_wardrobe_catalog)} collection profiles inside single file:")
        print(f"👉 TARGET MANIFEST ABSOLUTE PATH LOCATION: {output_manifest_path}")
        print("==========================================================")

if __name__ == "__main__":
    run_module_2_batch_processing()
